# Copy to .env and fill in real values, or `export` directly in your shell.
# zammadog reads these via DatadogClient.from_env().

# Required — Datadog API + Application keys
# Create at: https://app.datadoghq.com/organization-settings/api-keys
#                       /organization-settings/application-keys
DD_API_KEY=your-datadog-api-key-here
DD_APP_KEY=your-datadog-application-key-here

# Optional — Datadog site. Default: datadoghq.com
# Use datadoghq.eu for EU tenants, us3.datadoghq.com / us5.datadoghq.com / ap1.datadoghq.com as applicable.
DD_SITE=datadoghq.com

# --- CloudWatch ---
# CloudWatch uses the boto3 default credential + region chain.
# Ensure your AWS creds and region are configured (e.g. via `aws configure`,
# AWS_REGION / AWS_PROFILE env vars, or EC2/ECS metadata).
# If the region is unresolved, zammadog exits with a clear error.
# AWS_ACCESS_KEY_ID=...
# AWS_SECRET_ACCESS_KEY=...
# AWS_REGION=us-east-1
